# ============================================================
# Variables de entorno – Producción (suempresa.com)
# ============================================================
# Copia este archivo como ".env" en el servidor y rellena
# todos los valores antes de ejecutar docker-compose up.
# ¡NUNCA subas el archivo .env real al repositorio!
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=sysccom
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA_SEGURA
POSTGRES_DB=sysccom_db

# Usada internamente por Prisma (el host es el nombre del servicio Docker)
DATABASE_URL="postgresql://sysccom:CAMBIA_ESTA_CONTRASENA_SEGURA@postgres:5432/sysccom_db?schema=public"

# ── APIs de proveedores ───────────────────────────────────────
SYSCOM_API_KEY=tu-api-key-de-syscom
# ABASTEO_API_KEY=tu-api-key-de-abasteo

# ── Pagos SPEI ────────────────────────────────────────────────
SPEI_CLABE=tu-clabe-interbancaria-18-digitos
SPEI_BANCO=STP
SPEI_BENEFICIARIO=SYSCCOM Integradores S.A. de C.V.

# ── Conekta (gateway de pagos) ────────────────────────────────
# CONEKTA_PUBLIC_KEY=key_xxxxx
# CONEKTA_PRIVATE_KEY=key_xxxxx
